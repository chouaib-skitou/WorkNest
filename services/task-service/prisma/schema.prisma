generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  firstName  String
  lastName   String
  email      String   @unique
  password   String
  role       Role     @default(ROLE_EMPLOYEE)
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tasks      Task[]   @relation("UserTasks") // One-to-many relation with Task
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  assignedTo  String
  user        User?      @relation("UserTasks", fields: [assignedTo], references: [id], onDelete: Cascade) // One-to-one relation with User
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum Role {
  ROLE_EMPLOYEE
  ROLE_MANAGER
  ROLE_ADMIN
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}
